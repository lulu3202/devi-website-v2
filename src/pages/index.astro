---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ArticleCard from '@components/ArticleCard.astro';
import TemplateCard from '@components/TemplateCard.astro';
import { articles } from '@data/articles';
import { templates } from '@data/templates';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const featuredArticles = articles.filter((a) => a.featured).slice(0, 3);
---

<BaseLayout title="Devi Priya K | AI Content & Visibility Systems">
  <Hero />

  <!-- Latest Writing -->
  <section class="section" style="background: var(--color-surface-alt);">
    <div class="container">
      <div class="section-header">
        <h2>Latest Writing</h2>
        <p>Tutorials and deep-dives on AI content systems, cloud, and GenAI.</p>
      </div>
      <div class="grid-3">
        {featuredArticles.map((article) => (
          <ArticleCard
            title={article.title}
            publication={article.publication}
            url={article.url}
            description={article.description}
          />
        ))}
      </div>
      <div class="home-section-cta">
        <a href={`${base}/writing/`} class="btn btn-outline">Read All Articles →</a>
      </div>
    </div>
  </section>

  <!-- Free Templates -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Free Templates</h2>
        <p>Claude Code project templates from every video. Set up in 5 minutes.</p>
      </div>
      <div class="grid-2">
        {templates.map((template) => (
          <TemplateCard
            slug={template.slug}
            title={template.title}
            description={template.description}
          />
        ))}
      </div>
      <div class="home-section-cta">
        <a href={`${base}/templates/`} class="btn btn-outline">See All Templates →</a>
      </div>
    </div>
  </section>
</BaseLayout>
