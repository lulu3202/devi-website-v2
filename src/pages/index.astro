---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ArticleCard from '@components/ArticleCard.astro';
import TemplateCard from '@components/TemplateCard.astro';
import { getCollection } from 'astro:content';
import { articles } from '@data/articles';
import { templates } from '@data/templates';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Latest 3 blog posts from content collection
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Fall back to static articles if no blog posts yet
const hasBlogPosts = blogPosts.length > 0;
const featuredArticles = articles.filter((a) => a.featured).slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Devi Priya K | AI Tutorials, Templates & Experiments">
  <Hero />

  <!-- Latest Posts -->
  <section class="section" style="background: var(--color-surface-alt);">
    <div class="container">
      <div class="section-header">
        <h2>Latest Posts</h2>
        <p>Tutorials and deep-dives on AI content systems, cloud, and GenAI.</p>
      </div>

      {hasBlogPosts ? (
        <div class="blog-listing blog-listing--home">
          {blogPosts.map((post) => (
            <article class="blog-card blog-card--sm">
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
                <h3 class="blog-card-title blog-card-title--sm">
                  <a href={`${base}/blog/${post.slug}/`}>{post.data.title}</a>
                </h3>
                <p class="blog-card-desc">{post.data.description}</p>
                <a href={`${base}/blog/${post.slug}/`} class="blog-read-link">Read post →</a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="grid-3">
          {featuredArticles.map((article) => (
            <ArticleCard
              title={article.title}
              publication={article.publication}
              url={article.url}
              description={article.description}
            />
          ))}
        </div>
      )}

      <div class="home-section-cta">
        <a href={`${base}/blog/`} class="btn btn-outline">Read All Posts →</a>
      </div>
    </div>
  </section>

  <!-- Free Templates -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Free Templates</h2>
        <p>Claude Code project templates from every video. Set up in 5 minutes.</p>
      </div>
      <div class="grid-2">
        {templates.map((template) => (
          <TemplateCard
            slug={template.slug}
            title={template.title}
            description={template.description}
          />
        ))}
      </div>
      <div class="home-section-cta">
        <a href={`${base}/templates/`} class="btn btn-outline">See All Templates →</a>
      </div>
    </div>
  </section>
</BaseLayout>
