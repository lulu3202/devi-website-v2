---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const tagGradients: Record<string, string> = {
  'Claude':        'linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%)',
  'AI Tools':      'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'LangGraph':     'linear-gradient(135deg, #11998e 0%, #38ef7d 100%)',
  'Agno':          'linear-gradient(135deg, #FC5C7D 0%, #6A3093 100%)',
  'RAG':           'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'AWS':           'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
  'Gemini':        'linear-gradient(135deg, #4285F4 0%, #34A853 100%)',
  'Python':        'linear-gradient(135deg, #3776ab 0%, #ffd343 100%)',
  'Certifications':'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
};
---

<BaseLayout
  title="Blog | Devi Priya K"
  description="Tutorials and deep-dives on AI content systems, cloud, and GenAI."
>
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Tutorials and deep-dives on AI content systems, cloud, and GenAI.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => {
          const firstTag = post.data.tags[0] ?? '';
          const gradient = tagGradients[firstTag] ?? 'linear-gradient(135deg, #FF6B6B 0%, #E85555 100%)';
          return (
            <article class="blog-card">
              <a href={`${base}/blog/${post.slug}/`} class="blog-card-cover-link">
                {post.data.image ? (
                  <img
                    src={`${base}/images/${post.data.image}`}
                    alt={post.data.title}
                    class="blog-card-cover-img"
                    width="400"
                    height="220"
                    loading="lazy"
                  />
                ) : (
                  <div class="blog-card-cover-gradient" style={`background: ${gradient};`}>
                    <span class="blog-card-cover-tag">{firstTag || 'AI'}</span>
                  </div>
                )}
              </a>
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  {post.data.tags.length > 0 && (
                    <div class="blog-card-tags">
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="blog-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <h2 class="blog-card-title">
                  <a href={`${base}/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <a href={`${base}/blog/${post.slug}/`} class="blog-read-link">Read post →</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section-sm" style="background: var(--color-surface-alt);">
    <div class="container" style="text-align: center;">
      <h2 style="margin-bottom: 0.75rem;">Get a free template with every video</h2>
      <p style="margin-bottom: 1.5rem;">Join the newsletter and get each new template delivered.</p>
      <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
      <iframe src="https://subscribe-forms.beehiiv.com/1cb0ab2b-0e1e-4224-a58f-e31b3e669c47" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 315px; margin: 0 auto; border-radius: 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
    </div>
  </section>
</BaseLayout>
