---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function readTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

const tagGradients: Record<string, string> = {
  'Claude':        'linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%)',
  'AI Tools':      'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'LangGraph':     'linear-gradient(135deg, #11998e 0%, #38ef7d 100%)',
  'Agno':          'linear-gradient(135deg, #FC5C7D 0%, #6A3093 100%)',
  'RAG':           'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'AWS':           'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
  'Gemini':        'linear-gradient(135deg, #4285F4 0%, #34A853 100%)',
  'Python':        'linear-gradient(135deg, #3776ab 0%, #ffd343 100%)',
  'Certifications':'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
};

// Build tag counts — only show tags with 2+ posts
const tagCounts: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const filterTags = Object.keys(tagCounts)
  .filter((t) => tagCounts[t] >= 2)
  .sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  title="Blog | Devi Priya K"
  description="Tutorials, experiments, and deep-dives on agentic AI, GenAI tools, and hands-on projects."
>
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Tutorials, experiments, and deep-dives on agentic AI, GenAI tools, and hands-on projects.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- Tag filter pills -->
      <div class="blog-filters" id="blog-filters">
        <button class="filter-pill active" data-filter="all">All</button>
        {filterTags.map((tag) => (
          <button class="filter-pill" data-filter={tag}>{tag}</button>
        ))}
      </div>

      <!-- Post count -->
      <p class="blog-post-count" id="blog-post-count">{posts.length} posts</p>

      <!-- Featured external post -->
      <div class="featured-post">
        <div class="featured-post-eyebrow">
          <span class="featured-badge">Latest</span>
          <span class="featured-meta">GEO &middot; AI Search &middot; May 2026</span>
        </div>
        <h2 class="featured-post-title">Getting Started with GEO: A Guide for Bloggers</h2>
        <p class="featured-post-desc">GEO is how you structure content so AI engines like ChatGPT and Perplexity cite it in their answers — even when users never visit your site. Covers the ACS Framework with a before/after example and 5-step action plan.</p>
        <div class="featured-post-links">
          <a href="https://medium.com/@devipriyakaruppiah/getting-started-with-generative-engine-optimization-geo-a-guide-for-bloggers-79c5b2c9d0d0" target="_blank" rel="noopener" class="featured-link featured-link-primary">Read on Medium →</a>
          <a href="https://youtu.be/d3zFGKVebGg" target="_blank" rel="noopener" class="featured-link">Watch on YouTube →</a>
          <a href="https://devislabai.com/templates/" target="_blank" rel="noopener" class="featured-link">Free template →</a>
        </div>
      </div>

      <div class="blog-grid" id="blog-grid">
        {posts.map((post) => {
          const firstTag = post.data.tags[0] ?? '';
          const gradient = tagGradients[firstTag] ?? 'linear-gradient(135deg, #FF6B6B 0%, #E85555 100%)';
          const mins = readTime(post.body);
          const tagsJson = JSON.stringify(post.data.tags);
          return (
            <article class="blog-card" data-tags={tagsJson}>
              <a href={`${base}/blog/${post.slug}/`} class="blog-card-cover-link">
                {post.data.image ? (
                  <img
                    src={`${base}/images/${post.data.image}`}
                    alt={post.data.title}
                    class="blog-card-cover-img"
                    width="400"
                    height="220"
                    loading="lazy"
                  />
                ) : (
                  <div class="blog-card-cover-gradient" style={`background: ${gradient};`}>
                    <span class="blog-card-cover-tag">{firstTag || 'AI'}</span>
                  </div>
                )}
              </a>
              <div class="blog-card-body">
                {post.data.tags.length > 0 && (
                  <div class="blog-card-tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="blog-tag">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 class="blog-card-title">
                  <a href={`${base}/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-footer">
                  <time datetime={post.data.date.toISOString()} class="blog-card-date">
                    {formatDate(post.data.date)}
                  </time>
                  <span class="blog-card-read">{mins} min read</span>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Follow CTA -->
  <section class="section-sm" style="background: var(--color-surface-alt);">
    <div class="container" style="text-align: center;">
      <p class="follow-label">Follow me for more →</p>
      <div class="follow-links">
        <a href="https://www.linkedin.com/in/devipriyak/" target="_blank" rel="noopener noreferrer" class="follow-link">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://www.youtube.com/@devislab" target="_blank" rel="noopener noreferrer" class="follow-link">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <a href="https://medium.com/@devipriyakaruppiah" target="_blank" rel="noopener noreferrer" class="follow-link">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
          Medium
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .filter-pill {
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--color-border, #e2e8f0);
    background: var(--color-surface-alt, #f8fafc);
    color: var(--color-text-muted, #64748b);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }

  .filter-pill:hover {
    background: var(--color-border, #e2e8f0);
    color: var(--color-text, #1e293b);
  }

  .filter-pill.active {
    background: var(--color-text, #1e293b);
    color: #fff;
    border-color: var(--color-text, #1e293b);
  }

  .blog-post-count {
    font-size: 0.85rem;
    color: var(--color-text-muted, #64748b);
    margin-bottom: 2rem;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted, #64748b);
  }

  .blog-card-read::before {
    content: '·';
    margin-right: 0.5rem;
  }

  .featured-post {
    border: 1px solid var(--color-border, #e2e8f0);
    border-left: 3px solid var(--color-text, #1e293b);
    background: var(--color-surface-alt, #f8fafc);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }

  .featured-post-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }

  .featured-badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-text, #1e293b);
    color: #fff;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
  }

  .featured-meta {
    font-size: 0.78rem;
    color: var(--color-text-muted, #64748b);
  }

  .featured-post-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.35;
    color: var(--color-text, #1e293b);
  }

  .featured-post-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted, #64748b);
    line-height: 1.65;
    margin: 0 0 1rem;
    max-width: 68ch;
  }

  .featured-post-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .featured-link {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-muted, #64748b);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border, #e2e8f0);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .featured-link:hover {
    color: var(--color-text, #1e293b);
    border-color: var(--color-text, #1e293b);
  }

  .featured-link-primary {
    color: var(--color-text, #1e293b);
    border-color: var(--color-text, #1e293b);
  }
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');
  const countEl = document.getElementById('blog-post-count');
  const total = cards.length;

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter ?? 'all';

      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');

      let visible = 0;
      cards.forEach((card) => {
        const tags: string[] = JSON.parse(card.dataset.tags ?? '[]');
        const show = filter === 'all' || tags.includes(filter);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (countEl) {
        countEl.textContent = filter === 'all'
          ? `${total} posts`
          : `Showing ${visible} of ${total} posts`;
      }
    });
  });
</script>
