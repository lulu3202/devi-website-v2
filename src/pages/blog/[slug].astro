---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Related posts: same tags, exclude current
const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.tags.some((t) => post.data.tags.includes(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const h2headings = headings.filter((h) => h.depth === 2);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const estReadTime = readingTime(post.body);
const canonicalUrl = post.data.canonicalUrl ?? `https://devislabai.com/blog/${post.slug}/`;

// Pick a gradient per post based on first tag
const tagGradients: Record<string, string> = {
  'Claude':       'linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%)',
  'AI Tools':     'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'LangGraph':    'linear-gradient(135deg, #11998e 0%, #38ef7d 100%)',
  'Agno':         'linear-gradient(135deg, #FC5C7D 0%, #6A3093 100%)',
  'RAG':          'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'AWS':          'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
  'Gemini':       'linear-gradient(135deg, #4285F4 0%, #34A853 100%)',
  'Python':       'linear-gradient(135deg, #3776ab 0%, #ffd343 100%)',
  'Certifications':'linear-gradient(135deg, #f7971e 0%, #ffd200 100%)',
};
const firstTag = post.data.tags[0] ?? '';
const coverGradient = tagGradients[firstTag] ?? 'linear-gradient(135deg, #FF6B6B 0%, #E85555 100%)';
---

<BaseLayout
  title={`${post.data.title} | Devi Priya K`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <link rel="canonical" href={canonicalUrl} slot="head" />

  <article class="blog-post">

    <!-- Hero: real image or gradient cover -->
    {post.data.image ? (
      <div class="post-hero-image">
        <img
          src={`${base}/images/${post.data.image}`}
          alt={post.data.title}
          width="1100"
          height="460"
          loading="eager"
        />
      </div>
    ) : (
      <div class="post-hero-gradient" style={`background: ${coverGradient};`}>
        <div class="post-hero-gradient-inner">
          <div class="post-hero-tags">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="post-hero-tag">{tag}</span>
            ))}
          </div>
          <h1 class="post-hero-gradient-title">{post.data.title}</h1>
          <p class="post-hero-gradient-desc">{post.data.description}</p>
        </div>
      </div>
    )}

    <div class="container post-layout">

      <!-- Sidebar: TOC -->
      {h2headings.length > 1 && (
        <aside class="post-toc">
          <p class="toc-label">Contents</p>
          <nav>
            <ul>
              {h2headings.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Main content -->
      <div class="post-main">

        <!-- Header (shown below gradient; simpler if using real image) -->
        <header class="post-header">
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            <span class="post-meta-sep">·</span>
            <span>{estReadTime}</span>
            {post.data.updated && (
              <>
                <span class="post-meta-sep">·</span>
                <span>Updated {formatDate(post.data.updated)}</span>
              </>
            )}
          </div>
          {post.data.image && (
            <>
              <h1 class="post-title">{post.data.title}</h1>
              <p class="post-description">{post.data.description}</p>
            </>
          )}
          {post.data.tags.length > 0 && (
            <div class="blog-card-tags" style="margin-top: 0.75rem;">
              {post.data.tags.map((tag) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          )}
        </header>

        <!-- YouTube embed (if youtubeVideoId is set in frontmatter) -->
        {post.data.youtubeVideoId && (
          <div class="post-youtube">
            <p class="post-youtube-label">Watch the video walkthrough</p>
            <div class="post-youtube-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${post.data.youtubeVideoId}`}
                title={post.data.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        )}

        <!-- Article body -->
        <div class="post-body prose">
          <Content />
        </div>

        <!-- Follow CTA -->
        <div class="post-newsletter">
          <p class="follow-label">Follow me for more →</p>
          <div class="follow-links">
            <a href="https://www.linkedin.com/in/devipriyak/" target="_blank" rel="noopener noreferrer" class="follow-link">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
            <a href="https://www.youtube.com/@devislab" target="_blank" rel="noopener noreferrer" class="follow-link">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="https://medium.com/@devipriyakaruppiah" target="_blank" rel="noopener noreferrer" class="follow-link">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
              Medium
            </a>
          </div>
        </div>

        <!-- Author -->
        <div class="post-author">
          <img
            src={`${base}/images/profile.jpeg`}
            alt="Devi Priya K"
            class="post-author-img"
            width="60"
            height="60"
          />
          <div>
            <p class="post-author-name">Devi Priya K</p>
            <p class="post-author-bio">Senior AI Product Manager and content creator. I build AI-powered content and visibility systems using Claude Code.</p>
            <a href={`${base}/about/`} class="post-author-link">About me →</a>
          </div>
        </div>

      </div>
    </div>
  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="section" style="background: var(--color-surface-alt);">
      <div class="container">
        <div class="section-header">
          <h2>Related Posts</h2>
        </div>
        <div class="blog-listing blog-listing--related">
          {related.map((p) => (
            <article class="blog-card blog-card--sm">
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={p.data.date.toISOString()}>{formatDate(p.data.date)}</time>
                </div>
                <h3 class="blog-card-title blog-card-title--sm">
                  <a href={`${base}/blog/${p.slug}/`}>{p.data.title}</a>
                </h3>
                <p class="blog-card-desc">{p.data.description}</p>
                <a href={`${base}/blog/${p.slug}/`} class="blog-read-link">Read post →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
