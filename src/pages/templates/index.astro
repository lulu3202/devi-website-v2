---
import BaseLayout from '@layouts/BaseLayout.astro';
import TemplateCard from '@components/TemplateCard.astro';
import { templates } from '@data/templates';
---

<BaseLayout
  title="Free Templates | Devi Priya K"
  description="Free Claude Code project templates from every video. Set up in 5 minutes."
>
  <div class="page-header">
    <div class="container">
      <h1>Free Templates</h1>
      <p>Claude Code project templates from every video. Set up in 5 minutes.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        {templates.map((template) => (
          <TemplateCard
            slug={template.slug}
            title={template.title}
            description={template.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section-sm" style="background: var(--color-surface-alt);">
    <div class="container" style="text-align: center;">
      <h2 style="margin-bottom: 0.75rem;">Get a free template with every video →</h2>
      <p style="margin-bottom: 1.5rem;">Join the newsletter and get each new template delivered.</p>
      <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
      <iframe src="https://subscribe-forms.beehiiv.com/1cb0ab2b-0e1e-4224-a58f-e31b3e669c47" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 315px; margin: 0 auto; border-radius: 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
    </div>
  </section>
</BaseLayout>
