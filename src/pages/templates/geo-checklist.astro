<!-- TAB 3: GEO SCORE CALCULATOR -->
<div id="tab-calculator" class="tab-content">
  <div class="section-label">Interactive Tool</div>
  <div class="section-title">GEO Score Calculator</div>
  <p class="section-desc">Check off each element present in your post. Your GEO score updates in real time. Aim for 70+ before publishing.</p>

  <div class="calculator">
    <div class="calc-items">
      {calcData.map((item, i) => (
        <div class="calc-item" data-index={i} data-pts={item.pts}>
          <div class="calc-checkbox" id={`cb-${i}`}></div>
          <div class="calc-item-text">
            <div class="calc-item-label">{item.label}</div>
            <div class="calc-item-desc">{item.desc}</div>
          </div>
          <div class="calc-item-pts" id={`pts-${i}`}>+{item.pts}</div>
        </div>
      ))}
    </div>

    <div class="score-display">
      <div class="score-number" id="scoreNum" style="color:var(--score-low)">0</div>
      <div class="score-label">GEO Score / 100</div>
      <div class="score-bar-track">
        <div class="score-bar-fill" id="scoreBar"></div>
      </div>
      <div class="score-verdict" id="scoreVerdict">Check items above to calculate your score.</div>

      <div class="score-actions">
        <button class="btn primary" onclick="copyResults()">Copy Score Report</button>
        <button class="btn" onclick="resetCalc()">Reset</button>
      </div>
    </div>
  </div>
</div>

<footer>
  <div>© 2026 Devi Priya K · <a href="https://devislabai.com">devislabai.com</a></div>
  <div>Part of the GEO Series · <a href="https://devislabai.com/templates">All Templates →</a></div>
</footer>

<script is:inline>
  var calcItems = Array.from(document.querySelectorAll('.calc-item'));
  var checked = calcItems.map(function() { return false; });

  calcItems.forEach(function(item, i) {
    item.querySelector('.calc-checkbox').addEventListener('click', function() { toggleCheck(i); });
    item.querySelector('.calc-item-label').addEventListener('click', function() { toggleCheck(i); });
  });

  function toggleCheck(i) {
    checked[i] = !checked[i];
    document.getElementById('cb-' + i).className = 'calc-checkbox' + (checked[i] ? ' checked' : '');
    document.getElementById('pts-' + i).className = 'calc-item-pts' + (checked[i] ? ' earned' : '');
    updateScore();
  }

  function updateScore() {
    var score = calcItems.reduce(function(sum, item, i) {
      return sum + (checked[i] ? parseInt(item.dataset.pts, 10) : 0);
    }, 0);
    var el = document.getElementById('scoreNum');
    var bar = document.getElementById('scoreBar');
    var verdict = document.getElementById('scoreVerdict');
    var color, bg, verdictText;
    if (score === 0) {
      color = 'var(--ink-muted)'; bg = 'var(--rule)';
      verdictText = 'Check items above to calculate your score.';
    } else if (score < 44) {
      color = 'var(--score-low)'; bg = 'var(--score-low)';
      verdictText = 'Not AI-citable yet. Focus on items 1–4 first — they account for 46 points.';
    } else if (score < 77) {
      color = 'var(--score-mid)'; bg = 'var(--score-mid)';
      verdictText = 'Partially optimized. Add FAQ schema and author bio to cross the 70% threshold.';
    } else if (score < 100) {
      color = 'var(--score-high)'; bg = 'var(--score-high)';
      verdictText = 'Good — this post is AI-citable. Test it in Perplexity and ChatGPT within 2 weeks.';
    } else {
      color = 'var(--score-high)'; bg = 'var(--score-high)';
      verdictText = 'Excellent. This post is fully GEO-optimized. Monitor citations monthly.';
    }
    el.textContent = score;
    el.style.color = color;
    bar.style.width = score + '%';
    bar.style.background = bg;
    verdict.textContent = verdictText;
  }

  function resetCalc() {
    checked = calcItems.map(function() { return false; });
    calcItems.forEach(function(_, i) {
      document.getElementById('cb-' + i).className = 'calc-checkbox';
      document.getElementById('pts-' + i).className = 'calc-item-pts';
    });
    updateScore();
  }

  function copyResults() {
    var score = calcItems.reduce(function(sum, item, i) {
      return sum + (checked[i] ? parseInt(item.dataset.pts, 10) : 0);
    }, 0);
    var lines = ['GEO Score Report — devislabai.com', 'Score: ' + score + '/100', '', 'Completed:'];
    calcItems.forEach(function(item, i) {
      var label = item.querySelector('.calc-item-label').textContent;
      var pts = item.dataset.pts;
      if (checked[i]) lines.push('✓ ' + label + ' (+' + pts + ')');
    });
    lines.push('', 'Missing:');
    calcItems.forEach(function(item, i) {
      var label = item.querySelector('.calc-item-label').textContent;
      var pts = item.dataset.pts;
      if (!checked[i]) lines.push('○ ' + label + ' (+' + pts + ')');
    });
    navigator.clipboard.writeText(lines.join('\n')).then(function() {
      alert('Score report copied to clipboard!');
    });
  }

  function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    document.getElementById('tab-' + name).classList.add('active');
    if (btn) btn.classList.add('active');
  }

  updateScore();
</script>
</body>
</html>
