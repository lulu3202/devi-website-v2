---
import BaseLayout from '@layouts/BaseLayout.astro';
import YouTubeEmbed from '@components/YouTubeEmbed.astro';
import TemplateCard from '@components/TemplateCard.astro';
import { templates } from '@data/templates';

export function getStaticPaths() {
  return templates.map((t) => ({ params: { slug: t.slug }, props: { template: t } }));
}

const { template } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Other templates to show in "More Free Templates"
const otherTemplates = templates.filter((t) => t.slug !== template.slug);
---

<BaseLayout
  title={`${template.title} | Devi Priya K`}
  description={template.description}
>
  <div class="page-header">
    <div class="container">
      <h1>{template.title}</h1>
      <p>{template.longDescription}</p>
    </div>
  </div>

  <section class="section">
    <div class="container template-page">

      <!-- Resource Links -->
      <div class="template-resources">
        <h2>Resources</h2>
        <div class="template-resource-links">
          {template.githubUrl ? (
            <a href={template.githubUrl} class="resource-card" target="_blank" rel="noopener noreferrer">
              <span class="resource-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              </span>
              <div>
                <strong>GitHub Repo</strong>
                <span>Browse the source code</span>
              </div>
              <span class="resource-arrow">→</span>
            </a>
          ) : null}

          {template.prdPromptUrl ? (
            <a href={template.prdPromptUrl} class="resource-card" target="_blank" rel="noopener noreferrer">
              <span class="resource-icon">📄</span>
              <div>
                <strong>PRD Prompt</strong>
                <span>The exact prompt used to build this</span>
              </div>
              <span class="resource-arrow">→</span>
            </a>
          ) : (
            <div class="resource-card resource-card--placeholder">
              <span class="resource-icon">📄</span>
              <div>
                <strong>PRD Prompt</strong>
                <span>Coming soon</span>
              </div>
            </div>
          )}

          {template.tutorialUrl ? (
            <a href={template.tutorialUrl} class="resource-card" target="_blank" rel="noopener noreferrer">
              <span class="resource-icon">✍️</span>
              <div>
                <strong>Full Tutorial</strong>
                <span>Step-by-step guide on Towards AI</span>
              </div>
              <span class="resource-arrow">→</span>
            </a>
          ) : (
            <div class="resource-card resource-card--placeholder">
              <span class="resource-icon">✍️</span>
              <div>
                <strong>Full Tutorial</strong>
                <span>Coming soon</span>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- YouTube Embed -->
      <div class="template-video">
        <h2>Video Walkthrough</h2>
        {template.youtubeVideoId ? (
          <YouTubeEmbed videoId={template.youtubeVideoId} title={template.title} />
        ) : (
          <div class="video-placeholder">
            <p>Video coming soon — <a href="https://www.youtube.com/@devislab" target="_blank" rel="noopener noreferrer" style="color: var(--color-coral);">subscribe on YouTube</a> to be notified.</p>
          </div>
        )}
      </div>

      <!-- Newsletter CTA -->
      <div class="template-newsletter">
        <h2>Get a free template with every video →</h2>
        <p>Every video I publish comes with a free template. Join the newsletter to get it delivered.</p>
        <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
        <iframe src="https://subscribe-forms.beehiiv.com/f2aa3d0d-ccfc-40ed-a524-e1068c747cdb" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 315px; margin: 0; border-radius: 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
      </div>

    </div>
  </section>

  <!-- More Free Templates -->
  <section class="section" style="background: var(--color-surface-alt);">
    <div class="container">
      <div class="section-header">
        <h2>More Free Templates</h2>
      </div>
      {otherTemplates.length > 0 ? (
        <div class="grid-2">
          {otherTemplates.map((t) => (
            <TemplateCard slug={t.slug} title={t.title} description={t.description} />
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: var(--color-text-muted);">More coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
