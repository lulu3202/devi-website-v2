---
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { articles } from '@data/articles';
---

<BaseLayout
  title="Writing | Devi Priya K"
  description="Tutorials and deep-dives on AI content systems, cloud, and GenAI. Published on Medium."
>
  <div class="page-header">
    <div class="container">
      <h1>Writing</h1>
      <p>
        Tutorials and deep-dives on AI content systems, cloud, and GenAI.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        {articles.map((article) => (
          <ArticleCard
            title={article.title}
            publication={article.publication}
            url={article.url}
            description={article.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section-sm" style="background: var(--color-surface-alt);">
    <div class="container" style="text-align: center;">
      <h2 style="margin-bottom: 1.5rem;">Get a free template with every video</h2>
      <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
      <iframe src="https://subscribe-forms.beehiiv.com/f2aa3d0d-ccfc-40ed-a524-e1068c747cdb" class="beehiiv-embed" data-test-id="beehiiv-embed" frameborder="0" scrolling="no" style="width: 560px; height: 315px; margin: 0 auto; border-radius: 0px !important; background-color: transparent; box-shadow: 0 0 #0000; max-width: 100%;"></iframe>
    </div>
  </section>
</BaseLayout>
