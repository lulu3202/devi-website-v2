---
interface Props {
  slug: string;
  title: string;
  description: string;
}

const { slug, title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="template-card">
  <div class="template-card-body">
    <h3 class="template-card-title">{title}</h3>
    <p class="template-card-desc">{description}</p>
    <a href={`${base}/templates/${slug}/`} class="template-card-link">
      Get Template →
    </a>
  </div>
</article>
