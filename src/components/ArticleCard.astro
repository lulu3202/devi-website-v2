---
import type { Publication } from '../data/articles';

interface Props {
  title: string;
  publication: Publication;
  url: string;
  description: string;
}

const { title, publication, url, description } = Astro.props;

const pubClass = publication === 'Towards AI' ? 'pub-towards-ai' : 'pub-medium';
const isPlaceholder = url === '#';
---

<article class="card">
  <span class={`card-pub-label ${pubClass}`}>{publication}</span>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  {isPlaceholder ? (
    <span class="card-link" style="color: var(--color-text-muted); cursor: default;">
      Coming soon →
    </span>
  ) : (
    <a
      href={url}
      class="card-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Read "${title}" on ${publication}`}
    >
      Read Article →
    </a>
  )}
</article>
